# Analyzer – environment variable configuration
# Copy this file to .env and adjust the values for your environment.
# Variables already set in your shell are NOT overridden by .env.

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
# Where fit output directories are written (one sub-dir per set_id + model)
ANALYZER_RESULTS_DIR=results

# Where combined reflectivity files live
ANALYZER_COMBINED_DATA_DIR=data/combined

# Where partial reflectivity files live
ANALYZER_PARTIAL_DATA_DIR=data/partial

# Where generated reports (Markdown, plots) are written
ANALYZER_REPORTS_DIR=reports

# File-name template for combined data – {set_id} is replaced at runtime
ANALYZER_COMBINED_DATA_TEMPLATE=REFL_{set_id}_combined_data_auto.txt

# Where model Python files live
ANALYZER_MODELS_DIR=models

# ---------------------------------------------------------------------------
# EIS settings  (only needed for EIS workflows)
# ---------------------------------------------------------------------------
# EIS_DATA_DIR=/path/to/eis-data
# EIS_FILE_PATTERN=*C02_?.mpt

# ---------------------------------------------------------------------------
# Neutron event reduction  (only needed for event-reduction workflows)
# ---------------------------------------------------------------------------
# NEUTRON_EVENT_DATA_PATH=/path/to/event/data.h5
# NEUTRON_FILTERED_OUTPUT_DIR=./filtered_events

# ---------------------------------------------------------------------------
# LLM / AuRE  (required for `create-model` Mode B and `assess-result` LLM eval)
# ---------------------------------------------------------------------------
# Typically goes in the USER-GLOBAL .env (see "Configuration / .env cascade"
# in the README) so every project picks up the same credentials.
#
# LLM_PROVIDER=openai            # openai | gemini | alcf | local
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...
# LLM_BASE_URL=                  # only for local/OpenAI-compat endpoints
# LLM_TEMPERATURE=0.0
# LLM_TIMEOUT=120
